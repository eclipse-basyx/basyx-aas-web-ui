{
  "name": "aas-web-ui",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "prebuild": "run-s lint:check test:run type-check",
    "build": "vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc -b --force",
    "lint": "eslint ./",
    "lint:check": "eslint ./ --max-warnings=0",
    "lint:fix": "eslint --fix",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:integration": "playwright test --config playwright.config.ts --project=integration-core",
    "test:integration:preview": "IT_TARGET=preview playwright test --config playwright.config.ts --project=integration-core",
    "test:integration:docker": "IT_TARGET=docker playwright test --config playwright.config.ts --project=integration-core",
    "test:integration:timeseries": "IT_DISABLE_WEBSERVER=true playwright test --config playwright.config.ts --project=integration-timeseries",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "dependencies": {
    "@aas-core-works/aas-core3.1-typescript": "^1.0.1",
    "@fontsource/roboto": "^5.2.10",
    "@mdi/font": "^7.4.47",
    "@plantuml/core": "1.2026.6",
    "@thatopen/components": "^3.4.6",
    "@thatopen/components-front": "^3.4.3",
    "@thatopen/fragments": "^3.4.6",
    "@thatopen/ui": "^3.4.6",
    "@thatopen/ui-obc": "^3.4.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "aas-package3-typescript": "^1.0.0",
    "apexcharts": "^5.16.0",
    "basyx-typescript-sdk": "^2.2.4",
    "html5-qrcode": "^2.3.8",
    "i18n-iso-countries": "^7.14.0",
    "iso-639-1": "^3.1.6",
    "js-yaml": "^5.2.1",
    "leaflet": "^1.9.4",
    "md5": "^2.3.0",
    "mime": "^4.1.0",
    "pinia": "^3.0.4",
    "prismjs": "^1.30.0",
    "qrcode": "^1.5.4",
    "three": "^0.185.1",
    "uuid": "^14.0.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vue3-apexcharts": "^1.11.1",
    "vuetify": "^4.1.3",
    "web-ifc": "^0.0.77"
  },
  "devDependencies": {
    "@intellectronica/ruler": "^0.3.44",
    "@playwright/test": "^1.61.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/md5": "^2.3.6",
    "@types/node": "^26.1.0",
    "@types/prismjs": "^1.26.6",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-config-vuetify": "^4.7.2",
    "eslint-plugin-jsdoc": "^63.0.12",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "pnpm": "11.10.0",
    "sass-embedded": "^1.100.0",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-fonts": "^2.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
