# Copy this file to .env and replace every placeholder before starting the stack.
# The local .env file is ignored by git in this example folder.

# Host port used by this single-container example.
# For production, place this UI endpoint behind your platform TLS ingress/load balancer.
PUBLIC_UI_PORT=3000
PUBLIC_BASE_PATH=/

# Optional local image names used by docker compose build.
AAS_WEB_UI_IMAGE=basyx-aas-web-ui:catena-xplorer-edc

# Internal deployment default: no browser user authentication.
# Protect the UI with your internal network, VPN, ingress, or reverse proxy controls.
CX_EDC_BFF_AUTH_MODE=none

# Optional: uncomment these if CX_EDC_BFF_AUTH_MODE=jwt.
# CX_EDC_BFF_AUTH_JWKS_URL=https://identity.example.test/realms/catena-x/protocol/openid-connect/certs
# CX_EDC_BFF_AUTH_ISSUER=https://identity.example.test/realms/catena-x
# CX_EDC_BFF_AUTH_AUDIENCE=basyx-aas-web-ui
# CX_EDC_BFF_REQUIRED_ROLES=catena-xplorer

# Consumer EDC Management API. This stays server-side in the BFF.
CX_EDC_DEFAULT_MANAGEMENT_URL=https://consumer-edc.example.test/management
CX_EDC_DEFAULT_API_KEY=<EDC_MANAGEMENT_API_KEY>
CX_EDC_DEFAULT_API_KEY_HEADER=X-Api-Key
CX_EDC_DEFAULT_PARTICIPANT_ID=<CONSUMER_PARTICIPANT_ID>
CX_EDC_DEFAULT_DSP_ENDPOINT=https://consumer-edc.example.test/api/v1/dsp

# Provider DSP endpoints accepted by the BFF. Use explicit HTTPS prefixes in production.
CX_EDC_ALLOWED_COUNTER_PARTY_ADDRESSES=https://counterparty-edc.example.test/api/v1/dsp
CX_EDC_ALLOW_INSECURE_COUNTER_PARTY_ADDRESSES=false

# Upstream request and asynchronous EDR polling settings.
CX_EDC_REQUEST_TIMEOUT_MS=30000
CX_EDC_EDR_POLLING_ATTEMPTS=60
CX_EDC_EDR_POLLING_INTERVAL_MS=2000
