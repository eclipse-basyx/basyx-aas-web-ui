{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "aas-web-ui: bff:build",
      "type": "shell",
      "args": [
        "bff:build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/aas-web-ui"
      },
      "windows": {
        "command": "pnpm.cmd"
      },
      "linux": {
        "command": "pnpm"
      },
      "osx": {
        "command": "pnpm"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "aas-web-ui: install & build",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/aas-web-ui"
      },
      "windows": {
        "command": "pnpm install; pnpm build",
        "options": {
          "shell": {
            "executable": "powershell.exe",
            "args": [
              "-Command"
            ]
          }
        }
      },
      "linux": {
        "command": "pnpm install && pnpm build",
        "options": {
          "shell": {
            "executable": "/bin/bash",
            "args": [
              "-c"
            ]
          }
        }
      },
      "osx": {
        "command": "pnpm install && pnpm build",
        "options": {
          "shell": {
            "executable": "/bin/zsh",
            "args": [
              "-c"
            ]
          }
        }
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "aas-web-ui: install",
      "type": "shell",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}/aas-web-ui"
      },
      "windows": {
        "command": "pnpm.cmd"
      },
      "linux": {
        "command": "pnpm"
      },
      "osx": {
        "command": "pnpm"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "aas-web-ui: build",
      "type": "shell",
      "args": [
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/aas-web-ui"
      },
      "windows": {
        "command": "pnpm.cmd"
      },
      "linux": {
        "command": "pnpm"
      },
      "osx": {
        "command": "pnpm"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "aas-web-ui: lint",
      "type": "shell",
      "args": [
        "lint"
      ],
      "options": {
        "cwd": "${workspaceFolder}/aas-web-ui"
      },
      "windows": {
        "command": "pnpm.cmd"
      },
      "linux": {
        "command": "pnpm"
      },
      "osx": {
        "command": "pnpm"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "aas-web-ui: lint:fix",
      "type": "shell",
      "args": [
        "lint:fix"
      ],
      "options": {
        "cwd": "${workspaceFolder}/aas-web-ui"
      },
      "windows": {
        "command": "pnpm.cmd"
      },
      "linux": {
        "command": "pnpm"
      },
      "osx": {
        "command": "pnpm"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "aas-web-ui: test",
      "type": "shell",
      "args": [
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}/aas-web-ui"
      },
      "windows": {
        "command": "pnpm.cmd"
      },
      "linux": {
        "command": "pnpm"
      },
      "osx": {
        "command": "pnpm"
      },
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "aas-web-ui: dev (port 3000)",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/aas-web-ui"
      },
      "windows": {
        "command": "Start-Process 'http://localhost:3000'; pnpm dev --port 3000",
        "options": {
          "shell": {
            "executable": "powershell.exe",
            "args": [
              "-Command"
            ]
          }
        }
      },
      "linux": {
        "command": "xdg-open http://localhost:3000; pnpm dev --port 3000",
        "options": {
          "shell": {
            "executable": "/bin/bash",
            "args": [
              "-c"
            ]
          }
        }
      },
      "osx": {
        "command": "open http://localhost:3000; pnpm dev --port 3000",
        "options": {
          "shell": {
            "executable": "/bin/zsh",
            "args": [
              "-c"
            ]
          }
        }
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*Local.*3000.*"
        }
      }
    }
  ]
}
